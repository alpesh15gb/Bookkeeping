{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ApexBooks",
  "version": "1.0.0",
  "identifier": "com.apexbooks.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "cd frontend && npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "ApexBooks",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.apexbooks.in http://localhost:5173 http://localhost:8000; img-src 'self' https://api.apexbooks.in data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
