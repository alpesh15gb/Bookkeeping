# Application
APP_ENV=development
DEBUG=true
SEED_ON_STARTUP=true

# Database (Docker Compose default)
DATABASE_URL=postgresql://postgres:production_secure_db_pass@db:5432/bookkeeping

# Redis (Docker Compose default)
REDIS_URL=redis://redis:6379/0

# JWT Authentication (REQUIRED — generate a strong secret for production)
# python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_BEFORE_DEPLOYING_TO_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://apexbooks.in,https://api.apexbooks.in

# Email (SMTP / SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@apexbooks.in

# File Storage (S3-compatible)
S3_BUCKET=bookkeeping-documents
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# IRP (Invoice Registration Portal) — NIC e-Invoice
IRP_BASE_URL=https://einvoice1-sandbox.nic.in
IRP_CLIENT_ID=
IRP_CLIENT_SECRET=
IRP_USERNAME=
IRP_PASSWORD=

# Rate Limiting
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_REPORTS=60/minute
RATE_LIMIT_DEFAULT=200/minute
